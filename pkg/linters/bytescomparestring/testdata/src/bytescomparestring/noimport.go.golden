package bytescomparestring

import "bytes"

func noImportEqual(a, b []byte) bool {
	return bytes.Equal(a, b) // want `string\(a\) == string\(b\) allocates; use bytes\.Equal\(a, b\) instead`
}

func noImportNotEqual(a, b []byte) bool {
	return !bytes.Equal(a, b) // want `string\(a\) != string\(b\) allocates; use !bytes\.Equal\(a, b\) instead`
}
